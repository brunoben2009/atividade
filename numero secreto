# Número secreto (definido no código)
numero_secreto = 7

# Loop com até 5 tentativas
for tentativa in range(1, 6):
    palpite = int(input(f"Tentativa {tentativa}: Digite seu palpite: "))

    if palpite == numero_secreto:
        print("Parabéns! Você acertou!")
        break
    elif palpite > numero_secreto:
        print("O número secreto é menor.")
    else:
        print("O número secreto é maior.")

# Se o jogador não acertou em nenhuma tentativa
else:
    print("Você perdeu! O número correto era:", numero_secreto)
