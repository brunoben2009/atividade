# Leitura dos dados
alunos = int(input("Quantidade de alunos: "))
monitores = int(input("Quantidade de monitores: "))
convidados = int(input("Quantidade de convidados: "))

# Cálculo do total
total = alunos + monitores + convidados

# Verificações
if total > 100:
    print("Erro: o número total de pessoas excede os 100 ingressos disponíveis.")
elif convidados > 20:
    print("Erro: o número de convidados excede o limite de 20 pessoas.")
else:
    print("Tudo certo! O evento está dentro dos limites estabelecidos.")
